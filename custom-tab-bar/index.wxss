.tabbar {
  position: fixed; left: 0; right: 0; bottom: 0; z-index: 100;
  display: flex;
  height: 160rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #1b1b1d;
  border-top: 1rpx solid rgba(255,255,255,0.07);
}
.tab {
  flex: 1;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 6rpx;
}
.tab-ico { width: 112rpx; height: 112rpx; opacity: 0.7; transition: opacity .15s; }
.tab.on .tab-ico { opacity: 1; }
.tab-text { font-size: 24rpx; color: #888888; line-height: 1; }
.tab.on .tab-text { color: #e5332a; }
