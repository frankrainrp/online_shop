/* tab */
.adm-tabs { display: flex; background: var(--bg-card); border-bottom: 1rpx solid var(--line); }
.adm-tab {
  flex: 1; text-align: center; padding: 28rpx 0;
  font-size: 28rpx; color: var(--text-sub); position: relative;
}
.adm-tab.on { color: var(--primary); font-weight: 600; }
.adm-tab.on::after {
  content: ''; position: absolute; left: 50%; bottom: 8rpx; transform: translateX(-50%);
  width: 48rpx; height: 6rpx; background: var(--primary); border-radius: 999rpx;
}

/* 列表行 */
.adm-row {
  display: flex; align-items: center;
  background: var(--bg-card); border-radius: 16rpx; padding: 20rpx;
  margin-top: 20rpx; box-shadow: var(--shadow);
}
.adm-thumb { width: 96rpx; height: 96rpx; border-radius: 12rpx; flex-shrink: 0; }
.adm-thumb-ph { background: rgba(229,51,42,0.08); }
.adm-title { font-size: 28rpx; color: var(--text); font-weight: 500; }
.ellipsis { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.adm-ops { display: flex; flex-direction: column; gap: 12rpx; flex-shrink: 0; }
.op-btn {
  font-size: 24rpx; color: var(--text-sub);
  border: 1rpx solid var(--line); border-radius: 999rpx; padding: 8rpx 24rpx; text-align: center;
}
.op-btn.del { color: var(--primary); border-color: var(--primary); }

/* 新增浮动按钮 */
.fab {
  position: fixed; right: 40rpx; bottom: 60rpx;
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: var(--primary); color: #fff;
  font-size: 56rpx; line-height: 92rpx; text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(229,51,42,0.35);
}

/* 表单浮层 */
.mask { position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 100; display: flex; align-items: flex-end; }
.sheet {
  width: 100%; background: var(--bg); border-radius: 28rpx 28rpx 0 0;
  max-height: 82vh; display: flex; flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
  padding: 0 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
.sheet-head { display: flex; align-items: center; justify-content: space-between; padding: 28rpx 0 12rpx; flex-shrink: 0; }
.sheet-close { font-size: 26rpx; color: var(--text-sub); }
/* 关键：min-height:0 让滚动区在 flex 列里真正滚动，保存按钮才不会被顶出屏幕 */
.sheet-body { flex: 1; min-height: 0; overflow-y: auto; padding-bottom: 24rpx; }

.field { padding: 14rpx 0; border-bottom: 1rpx solid var(--line); }
.field-label { font-size: 26rpx; color: var(--text-sub); display: block; margin-bottom: 12rpx; }
.field-ipt {
  background: var(--bg-card); border-radius: 14rpx; padding: 18rpx 22rpx;
  font-size: 28rpx; color: var(--text);
  width: 100%; box-sizing: border-box;
}
.picker-val { color: var(--text); }
.field-area {
  background: var(--bg-card); border-radius: 14rpx; padding: 18rpx 22rpx;
  font-size: 28rpx; color: var(--text); width: 100%; height: 130rpx;
  box-sizing: border-box;
}
.field-img { width: 200rpx; height: 200rpx; border-radius: 16rpx; overflow: hidden; }
.field-img-pic { width: 100%; height: 100%; }
.field-img-ph {
  width: 100%; height: 100%; background: var(--bg-card); border-radius: 16rpx;
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10rpx;
  font-size: 24rpx; color: var(--primary); border: 2rpx dashed var(--primary);
}
.field-img-ph::before {
  content: '+'; font-size: 48rpx; line-height: 1; color: var(--primary);
}

.sheet-save { margin-top: 24rpx; font-size: 32rpx; padding: 24rpx 0; flex-shrink: 0; }
.sheet-save.disabled { opacity: 0.5; }
