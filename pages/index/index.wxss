/* 自定义 tabBar 占位，避免内容被盖住 */
.page { padding-bottom: 250rpx; }

/* 品牌 Hero */
.hero {
  position: relative;
  display: flex; align-items: center; justify-content: space-between;
  margin: 16rpx 24rpx 0;
  padding: 28rpx 32rpx;
  border-radius: 24rpx;
  background: linear-gradient(120deg, #e5332a 0%, #8c1410 55%, #1a1a1a 100%);
  overflow: hidden;
}
.hero-left { display: flex; flex-direction: column; z-index: 1; }
.hero-title { font-size: 46rpx; font-weight: 800; color: #fff; letter-spacing: 2rpx; }
.hero-sub { font-size: 24rpx; color: rgba(255,255,255,0.88); margin-top: 12rpx; }
.hero-mascot { width: 170rpx; height: 170rpx; margin: -10rpx -8rpx -10rpx 0; }

/* 搜索栏 */
.searchbar { padding: 20rpx 24rpx 16rpx; background: var(--bg); }
.search-box {
  display: flex; align-items: center;
  background: var(--bg-card); border-radius: 999rpx; border: 1rpx solid var(--line);
  padding: 16rpx 28rpx; box-shadow: var(--shadow);
}
.search-ico {
  width: 28rpx; height: 28rpx; margin-right: 16rpx; border-radius: 50%;
  border: 4rpx solid var(--text-mute); position: relative; box-sizing: content-box;
}
.search-ico::after {
  content: ''; position: absolute; right: -10rpx; bottom: -8rpx;
  width: 14rpx; height: 4rpx; background: var(--text-mute); transform: rotate(45deg); border-radius: 2rpx;
}
.search-ph { font-size: 26rpx; color: var(--text-mute); }

/* 轮播 */
.swiper { width: 100%; height: 300rpx; border-radius: 20rpx; overflow: hidden; margin-top: 8rpx; }
.swiper-img { width: 100%; height: 100%; background: var(--grad-points); }
.swiper-title {
  position: absolute; left: 24rpx; bottom: 40rpx;
  color: #fff; font-size: 32rpx; font-weight: 700;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.4);
}
.swiper-ph {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  background: var(--grad-points); gap: 14rpx;
}
.ph-tag {
  font-size: 22rpx; color: #fff; border: 1rpx solid rgba(255,255,255,0.8);
  padding: 4rpx 18rpx; border-radius: 999rpx;
}
.ph-text { font-size: 24rpx; color: rgba(255,255,255,0.9); }

/* 图标导航 */
.nav {
  display: flex; margin-top: 24rpx;
  background: var(--bg-card); border-radius: 20rpx; padding: 28rpx 0;
  border: 1rpx solid var(--line); box-shadow: var(--shadow);
}
.nav-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 14rpx; }
.nav-ico {
  width: 72rpx; height: 72rpx; border-radius: 24rpx;
  background: rgba(229,51,42,0.08);   /* 缺图时的浅红占位 */
}
.nav-label { font-size: 24rpx; color: var(--text-sub); }

/* 商品流标题 */
.feed-title { display: flex; align-items: center; gap: 14rpx; margin: 36rpx 0 20rpx; }
.feed-bar { width: 8rpx; height: 32rpx; background: var(--primary); border-radius: 999rpx; }
.feed-title text { font-size: 32rpx; font-weight: 700; color: var(--text); }

/* 商品流网格 */
.feed { display: flex; flex-wrap: wrap; gap: 20rpx; }
.g-card {
  width: calc(50% - 14rpx);
  background: var(--bg-card); border-radius: 20rpx; overflow: hidden;
  border: 1rpx solid var(--line); box-shadow: var(--shadow);
}
.g-img { width: 100%; height: 340rpx; background: var(--bg-card-2); }
.g-body { padding: 18rpx 20rpx 22rpx; }
.g-name {
  font-size: 26rpx; color: var(--text); line-height: 1.4;
  display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden;
  min-height: 72rpx;
}
.g-bottom { display: flex; align-items: center; justify-content: space-between; margin-top: 12rpx; }
.g-price { display: flex; align-items: baseline; }
.g-price-num { font-size: 36rpx; font-weight: 700; color: var(--primary); }
.g-price-unit { font-size: 22rpx; color: var(--primary); margin-left: 4rpx; }
.g-cat { font-size: 20rpx; color: var(--text-mute); background: var(--bg-card-2); padding: 4rpx 14rpx; border-radius: 8rpx; }

.feed-end { text-align: center; color: var(--text-mute); font-size: 24rpx; padding: 36rpx 0; }
