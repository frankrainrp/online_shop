<view class="page wrap">
  <view class="tabs">
    <view wx:for="{{ filters }}" wx:key="*this"
          class="tab {{ filter===item?'on':'' }}" data-f="{{ item }}" bindtap="setFilter">{{ item }}</view>
  </view>

  <view wx:if="{{ list.length }}" class="fade-in">
    <view wx:for="{{ list }}" wx:key="_id"
          wx:if="{{ filter==='全部' || item.status===filter }}" class="redeem-row">
      <image class="r-img" src="{{ item.goodsImage }}" mode="aspectFill" lazy-load />
      <view class="col" style="flex:1; margin-left:20rpx">
        <text class="title" style="font-size:28rpx">{{ item.goodsName }}</text>
        <text class="mute" style="margin-top:6rpx">单号 {{ item.code }}</text>
        <text class="mute" style="margin-top:4rpx">{{ item.dateStr }} · {{ item.cost }}积分</text>
      </view>
      <view class="col" style="align-items:flex-end">
        <text class="status status-{{ item.statusClass }}">{{ item.status }}</text>
        <view wx:if="{{ item.status==='待核销' }}" class="code-btn" data-item="{{ item }}" bindtap="showCode">查看券码</view>
      </view>
    </view>
  </view>
  <view wx:elif="{{ loading }}">
    <view wx:for="{{ [1,2,3] }}" wx:key="*this" class="sk-row">
      <view class="sk sk-thumb"></view>
      <view class="sk-col">
        <view class="sk sk-line mid"></view>
        <view class="sk sk-line short"></view>
      </view>
    </view>
  </view>
  <view wx:else class="empty">还没有兑换记录，去积分兑换看看吧 ~</view>
</view>
