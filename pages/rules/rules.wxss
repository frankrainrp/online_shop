.page { padding-top: 8rpx; }
.doc {
  background: var(--bg-card); border: 1rpx solid var(--line);
  border-radius: 20rpx; padding: 32rpx; margin-top: 16rpx;
}
.doc-title { display: block; font-size: 36rpx; font-weight: 700; color: var(--text); text-align: center; }
.doc-meta { display: block; font-size: 24rpx; color: var(--text-sub); line-height: 1.7; margin-top: 20rpx; padding-bottom: 20rpx; border-bottom: 1rpx solid var(--line); }

.sec { margin-top: 28rpx; }
.sec-h { display: block; font-size: 28rpx; font-weight: 600; color: var(--text); margin-bottom: 12rpx; }
.sec-p { display: block; font-size: 25rpx; color: var(--text-sub); line-height: 1.75; margin-bottom: 8rpx; }

.doc-foot { display: block; font-size: 24rpx; color: var(--text-mute); margin-top: 32rpx; line-height: 1.7; }
