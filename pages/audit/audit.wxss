.page { padding-bottom: 60rpx; }

.filter-row {
  display: flex; align-items: center; gap: 20rpx;
  margin-top: 24rpx; margin-bottom: 8rpx;
}
.filter-label { font-size: 24rpx; color: var(--text-sub); }
.filter-val {
  font-size: 26rpx; color: var(--text);
  background: var(--bg-card); border: 1rpx solid var(--line);
  border-radius: 999rpx; padding: 10rpx 28rpx;
}

.log-row {
  margin-top: 20rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--line);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
}
.row.between { display: flex; justify-content: space-between; align-items: center; }
.log-action {
  font-size: 28rpx; font-weight: 700; color: var(--primary);
}
.log-time { font-size: 22rpx; color: var(--text-mute); }
.log-summary {
  display: block; margin-top: 12rpx;
  font-size: 28rpx; color: var(--text); line-height: 1.5;
}
.log-op { display: block; margin-top: 10rpx; font-size: 22rpx; color: var(--text-sub); }

.loading-tip { text-align: center; color: var(--text-mute); font-size: 24rpx; padding: 32rpx 0; }
