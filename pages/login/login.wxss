.login-wrap {
  min-height: 100vh; box-sizing: border-box;
  display: flex; flex-direction: column; align-items: center;
  padding: 140rpx 48rpx 0;
}
.brand { width: 200rpx; height: 200rpx; }
.title { font-size: 44rpx; font-weight: 800; color: var(--text); margin-top: 20rpx; }
.slogan { font-size: 26rpx; color: var(--text-sub); margin-top: 12rpx; }

.card {
  margin-top: 80rpx; width: 100%; box-sizing: border-box;
  background: var(--bg-card); border: 1rpx solid var(--line);
  border-radius: 24rpx; padding: 48rpx 40rpx;
  display: flex; flex-direction: column; align-items: center;
}
.card-title { font-size: 32rpx; font-weight: 700; color: var(--text); }
.card-sub { font-size: 24rpx; color: var(--text-sub); margin-top: 12rpx; text-align: center; line-height: 1.6; }

.phone-btn {
  margin-top: 48rpx; width: 100%;
  background: var(--primary); color: #fff;
  font-size: 32rpx; font-weight: 700;
  border-radius: 999rpx; padding: 24rpx 0;
}
.phone-btn::after { border: none; }
.phone-btn.disabled { opacity: 0.6; }

.agree { margin-top: 32rpx; font-size: 22rpx; color: var(--text-mute); line-height: 1.7; text-align: center; }
.agree .link { color: var(--primary); }

.staff-entry { margin-top: 60rpx; font-size: 24rpx; color: var(--text-mute); }
