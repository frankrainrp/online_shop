.brand-mascot { display: block; width: 240rpx; height: 240rpx; margin: 40rpx auto 0; }
.login-card {
  margin-top: 24rpx;
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 56rpx 40rpx;
  border: 1rpx solid var(--line);
  box-shadow: var(--shadow);
  display: flex;
  flex-direction: column;
}
.login-title { font-size: 40rpx; font-weight: 700; color: var(--text); }
.login-sub { font-size: 26rpx; color: var(--text-sub); margin-top: 12rpx; }

.login-ipt {
  margin-top: 48rpx;
  background: var(--bg);
  border-radius: 16rpx;
  padding: 26rpx 28rpx;
  font-size: 30rpx;
  color: var(--text);
}
.ph { color: var(--text-mute); }

.login-btn { margin-top: 40rpx; }
.login-btn.disabled { opacity: 0.5; }
.login-btn.ghost { background: var(--bg); color: var(--primary); border: 1rpx solid var(--primary); }

.login-tip { font-size: 22rpx; color: var(--text-mute); margin-top: 32rpx; line-height: 1.6; }

/* 入口/链接行 */
.link-row { display: flex; justify-content: space-between; margin-top: 32rpx; }
.link-row.center { justify-content: center; }
.link { font-size: 24rpx; color: var(--text-sub); }
.link.danger { color: var(--primary); }

/* 启用二维码区 */
.enroll-box {
  margin-top: 40rpx; padding-top: 32rpx;
  border-top: 1rpx dashed var(--line);
  display: flex; flex-direction: column; align-items: center;
}
.enroll-title { font-size: 28rpx; font-weight: 700; color: var(--text); }
.qr-frame {
  margin-top: 24rpx; padding: 20rpx;
  background: #fff; border-radius: 20rpx;
}
.enroll-sub { font-size: 22rpx; color: var(--text-mute); margin-top: 16rpx; }
.secret-row {
  margin-top: 24rpx; width: 100%;
  background: var(--bg); border-radius: 16rpx; padding: 20rpx 24rpx;
  display: flex; flex-direction: column; align-items: center;
}
.secret-val {
  margin-top: 8rpx; font-size: 26rpx; font-weight: 700; color: var(--text);
  word-break: break-all; text-align: center; letter-spacing: 2rpx;
}
.enroll-warn { font-size: 22rpx; color: var(--primary-2); margin-top: 20rpx; line-height: 1.6; text-align: center; }
