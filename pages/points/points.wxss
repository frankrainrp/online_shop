.big-card {
  margin-top: 24rpx;
  background: var(--grad-points);
  border-radius: 28rpx;
  padding: 40rpx;
  display: flex; flex-direction: column;
}
.progress-wrap { margin-top: 24rpx; }
.progress-bar { height: 12rpx; background: var(--bg-card-2); border-radius: 999rpx; overflow: hidden; }
.progress-fill { height: 100%; background: var(--grad-points); border-radius: 999rpx; }

.action-card {
  flex: 1;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex; flex-direction: column; gap: 10rpx;
  border: 1rpx solid rgba(229,51,42,0.45);   /* 红描边，暗底上看得见且呼应参考图金属红边 */
}
