.page { padding-bottom: 250rpx; }
.mypoints {
  margin-top: 24rpx;
  background: var(--grad-points);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  display: flex; align-items: center; justify-content: space-between;
}
.points-num.small { font-size: 52rpx; }
.records-btn { padding: 14rpx 28rpx; border-radius: 999rpx; font-size: 26rpx; }

.cats { display: flex; gap: 16rpx; margin-top: 28rpx; overflow-x: auto; }
.cat {
  flex-shrink: 0;
  font-size: 26rpx; color: var(--text-sub);
  padding: 12rpx 28rpx; border-radius: 999rpx; background: var(--bg-card);
}
.cat.on { background: var(--primary); color: #fff; }

.goods-grid { display: flex; flex-wrap: wrap; gap: 20rpx; margin-top: 24rpx; }
.goods-card {
  width: calc(50% - 10rpx);
  background: var(--bg-card);
  border: 1rpx solid var(--line);
  border-radius: 20rpx;
  padding: 16rpx;
  display: flex; flex-direction: column;
}
.goods-img { width: 100%; height: 280rpx; border-radius: 16rpx; background: var(--bg-card-2); }
.goods-name { font-size: 26rpx; color: var(--text); margin-top: 14rpx; }
.ellipsis { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.redeem-btn {
  margin-top: 16rpx;
  background: var(--grad-points);
  color: #fff; text-align: center;
  font-size: 26rpx; font-weight: 600;
  padding: 16rpx 0; border-radius: 999rpx;
}
.redeem-btn.disabled { background: var(--bg-card-2); color: var(--text-mute); }
