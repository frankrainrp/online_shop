<view class="page wrap">
  <view class="code-card">
    <!-- 头部会员信息 -->
    <view class="row" style="width:100%">
      <image class="avatar" src="{{ user.avatarUrl }}" mode="aspectFill" />
      <view class="col" style="margin-left:20rpx">
        <text class="title">{{ user ? user.nickName : '会员' }}</text>
        <view class="tag-gold tag" style="margin-top:8rpx">{{ levelName }}</view>
      </view>
    </view>

    <!-- 二维码区：会员号生成真二维码，店员可直接扫码加分/核销 -->
    <view class="qr-box">
      <canvas canvas-id="qrcanvas" class="qr-canvas" style="width:{{ qrPx }}px; height:{{ qrPx }}px"></canvas>
    </view>

    <text class="sub" style="margin-top:32rpx">向店员出示二维码即可积分或兑换</text>
    <view class="refresh" bindtap="refresh">⟳ 刷新</view>
  </view>
</view>
