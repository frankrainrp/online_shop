.page { padding-bottom: 250rpx; }
.code-card {
  margin-top: 40rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
  padding: 40rpx;
  display: flex; flex-direction: column; align-items: center;
}
.avatar { width: 88rpx; height: 88rpx; border-radius: 50%; background: var(--bg-card-2); }

.qr-box {
  margin-top: 40rpx;
  width: 440rpx; height: 440rpx;
  background: #fff;
  border-radius: 24rpx;
  display: flex; align-items: center; justify-content: center;
  position: relative;
}
/* canvas 实际边长由 JS 按屏宽换算后内联设置（与绘制 px 一致），居中显示 */
.qr-canvas { display: block; }

.refresh {
  margin-top: 28rpx;
  font-size: 26rpx; color: var(--primary);
  padding: 12rpx 32rpx; border: 1rpx solid var(--primary); border-radius: 999rpx;
}
