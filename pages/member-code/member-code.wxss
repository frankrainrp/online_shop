.page { padding-bottom: 250rpx; }
.code-card {
  margin-top: 40rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
  padding: 40rpx;
  display: flex; flex-direction: column; align-items: center;
}
.avatar { width: 88rpx; height: 88rpx; border-radius: 50%; background: var(--bg-card-2); }

.qr-box {
  margin-top: 40rpx;
  width: 440rpx; height: 440rpx;
  background: #fff;
  border-radius: 24rpx;
  display: flex; align-items: center; justify-content: center;
  position: relative;
}
.qr-canvas { width: 0; height: 0; }
.qr-placeholder { display: flex; flex-direction: column; align-items: center; padding: 0 24rpx; }
.qr-ph-icon { font-size: 80rpx; }
.member-no {
  margin-top: 12rpx;
  font-size: 30rpx; font-weight: 700; color: #1a1a1a;
  word-break: break-all; text-align: center;
}
.qr-placeholder .mute { color: #888; }

.refresh {
  margin-top: 28rpx;
  font-size: 26rpx; color: var(--primary);
  padding: 12rpx 32rpx; border: 1rpx solid var(--primary); border-radius: 999rpx;
}
